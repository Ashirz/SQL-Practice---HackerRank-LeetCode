/*
Title: The PADS
Platform: HackerRank
Category: Advance Select
URL: https://www.hackerrank.com/challenges/the-pads/problem
Dialect: MySQL 
*/

Select concat(Name,'(',left(occupation,1),')') 
from occupations 
order by name;
Select concat('There are a total of ', count(occupation),' ',lower(occupation), 's.') 
from occupations 
Group by occupation 
Order by count(occupation) asc, lower(occupation);

