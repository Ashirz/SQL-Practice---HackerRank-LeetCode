/*
Title: Print Prime Numbers
Platform: HackerRank
Category: Alternative Queries
URL: https://www.hackerrank.com/challenges/print-prime-numbers/problem
Dialect: MySQL 
*/

With RECURSIVE numbers as(Select 2 as n 
union all 
Select n+1 from numbers 
where n<1000)

Select group_concat(n separator '&') from numbers t1 where not EXISTS 
(Select 1 from numbers t2 
where t2.n<=sqrt(t1.n) 
and t1.n%t2.n =0 
and t1.n<>t2.n);

