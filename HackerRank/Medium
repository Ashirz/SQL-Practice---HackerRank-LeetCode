/*
Title: Binary Tree Nodes
Platform: HackerRank
Category: Advance Select
URL: https://www.hackerrank.com/challenges/binary-search-tree-1/problem
Dialect: MySQL 
*/

Select n, case when p is null then 'Root' when n in (Select distinct p from bst where p is not null) then 'Inner' else 'Leaf' end 
from bst order by n;

