/*
Title: The Report
Platform: HackerRank
Category: Basic Join
URL: https://www.hackerrank.com/challenges/the-report/problem
Dialect: MySQL 
*/

Select case 
when grade>=8 then name else 'NULL' END ,
grade,marks 
from Students 
left join Grades on marks between min_mark and max_mark 
order by grade desc,name asc;

