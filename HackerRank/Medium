/*
Title: New Companies
Platform: HackerRank
Category: Advance Select
URL: https://www.hackerrank.com/challenges/the-company/problem
Dialect: MySQL 
*/

Select e.company_code, c.founder, 
count(distinct lead_manager_code), 
count(distinct senior_manager_code), count(distinct manager_code), count(distinct employee_code)
from Employee e
Join Company c on e.company_code = c.company_code
Group by e.company_code, c.founder
Order by e.company_code;

