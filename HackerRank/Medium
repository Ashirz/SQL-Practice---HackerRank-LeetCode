/*
Title: Symmetric Pairs
Platform: HackerRank
Category: Advanced Join
URL: https://www.hackerrank.com/challenges/symmetric-pairs/problem
Dialect: MySQL 
*/

Select f1.X, f1.Y
from Functions f1
join Functions f2 ON f1.X = f2.Y AND f1.Y = f2.X
group by f1.X, f1.Y
-- Ensure X < Y for distinct pairs, or check for multiple X=Y rows
having f1.X < f1.Y OR COUNT(*) > 1
order by f1.X;

