/*
Title: Placements
Platform: HackerRank
Category: Advanced Join
URL: https://www.hackerrank.com/challenges/placements/problem
Dialect: MySQL 
*/

Select s.Name
from Students s
join Friends f ON s.ID = f.ID
join Packages p1 ON s.ID = p1.ID       -- Student's own salary
join Packages p2 ON f.Friend_ID = p2.ID -- Friend's salary
where p2.Salary > p1.Salary             -- Filter condition
order by p2.Salary;                     -- Required for this challenge

