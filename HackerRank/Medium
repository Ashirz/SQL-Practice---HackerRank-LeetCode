/*
Title: SQL Project Planning
Platform: HackerRank
Category: Advanced Join
URL: https://www.hackerrank.com/challenges/sql-projects/problem
Dialect: MySQL 
*/

With find_gaps as(Select *,case when lag(end_date) over(order by start_date)=start_date then 0 else 1 end as gap_marker from projects),
task_group as( Select *, sum(gap_marker) over(order by start_date)as tasks from find_gaps)
Select min(start_date), max(end_date) from task_group group by tasks
Order by count(*),min(start_date);

